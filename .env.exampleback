# Copy to .env and fill in values
GOOGLE_API_KEY=your_google_api_key
# Modal auth: run `modal token new` in your terminal (no env var needed)

# Optional: GitHub PAT for a dedicated CodeMark bot account.
# If set, PRs are created as this account instead of the end-user's OAuth token.
# Needs repo (read/write) scope. Create a machine user or GitHub App for this.
# CODEMARK_BOT_TOKEN=ghp_...
